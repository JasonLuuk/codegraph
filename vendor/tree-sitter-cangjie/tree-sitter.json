{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "cangjie",
      "camelcase": "Cangjie",
      "scope": "source.cj",
      "path": ".",
      "file-types": ["cangjie", "cj"]
    }
  ],
  "metadata": {
    "version": "1.1.0",
    "license": "MIT",
    "description": "Cangjie grammar for tree-sitter (vendored, C scanner port)",
    "authors": [{ "name": "Cangjie-SIG" }],
    "links": {
      "repository": "https://gitcode.com/Cangjie-SIG/tree-sitter-cangjie"
    }
  },
  "bindings": {
    "c": false,
    "go": false,
    "node": false,
    "python": false,
    "rust": false,
    "swift": false
  }
}
